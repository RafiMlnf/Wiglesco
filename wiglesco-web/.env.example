# ==============================================
# WiggleAI — Environment Variables Template
# Copy this to .env and fill in your values
# ==============================================

# ── App ──────────────────────────────────────
APP_NAME="WiggleAI API"
DEBUG=true
ENVIRONMENT=development

# ── Security ─────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production

# ── Database (PostgreSQL) ─────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/wiggleai

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Storage (Cloudflare R2) ───────────────────
# Get from: Cloudflare Dashboard > R2 > API Tokens
S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your_r2_access_key
S3_SECRET_ACCESS_KEY=your_r2_secret_key
S3_BUCKET_NAME=wiggleai-media
S3_PUBLIC_URL=https://media.wiggleai.app

# ── AI Models ─────────────────────────────────
MODEL_CACHE_DIR=./ml/models
DEVICE=cuda        # cuda | cpu | mps
MODEL_PRECISION=fp16

# ── Processing ────────────────────────────────
MAX_FILE_SIZE_MB=50
MAX_IMAGE_DIMENSION=4096
PROCESSING_TIMEOUT_SECONDS=300

# ── Stripe ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_STUDIO=price_...

# ── Sentry ────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ── Frontend (Next.js) ────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
